<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Habitaciones</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-iYQeCzEYFbKjA/T2uDLTpkwGzCiq6soy8tYaI1GyVh/UjpbCx/TYkiZhlZB6+fzT"
      crossorigin="anonymous"
    />
  </head>
  <body class="text-bg-dark">
    <div class="container">
        <div class="row mt-5">
            <div class="col">
              <h3>Dar de alta una nueva habitación</h3>
            </div>
        </div>
        <div class="container">
            <h5>Introducir la información que se solicita</h5>
            <form action="/routes/rooms.js" method="post">
                <div class="col-md-6">
                    <label for="roomNumber" class="form-label">Número de habitación:</label>
                    <input id="roomNumber" name="roomNumber" type="number" class="form-control" required>
                </div>
                <div class="col-md-6">
                    <label for="roomType" class="form-label">Tipo de habitación:</label>
                    <input id="roomType" name="roomType" type="text" class="form-control" required>
                </div>
                <div class="col-md-6">
                    <label for="roomPrice" class="form-label">Precio de la habitación:</label>
                    <input id="roomPrice" name="roomPrice" type="number" class="form-control" required>
                </div>
                <div class="col-md-6">
                    <label for="roomStatus" class="form-label">Estado de la habitación:</label>
                    <input id="roomStatus" name="roomStatus" type="boolean" class="form-control" required>
                </div>

            </form>
        </div>
        <div class="row mt-5">
            <div class="col">
                <a class="btn btn-block btn-primary"  className="saveAndUpload" href="home.html" role="button">Guardad y volver</a>
            </div>
            <div class="col">
                <a class="btn btn-block btn-primary"  className="discard" href="home.html" role="button">Descartar cambios</a>
            </div>
        </div>
    </div>
   
    <script
      src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.6/dist/umd/popper.min.js"
      integrity="sha384-oBqDVmMz9ATKxIep9tiCxS/Z9fNfEXiDAYTujMAeBAsjFuCZSmKbSSUnQlmh/jp3"
      crossorigin="anonymous"
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/js/bootstrap.min.js"
      integrity="sha384-7VPbUDkoPSGFnVtYi0QogXtr74QeVeeIs99Qfg5YCF+TidwNdjvaKZX19NZ/e6oz"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
