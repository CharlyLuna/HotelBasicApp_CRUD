<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mi Cuenta</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-iYQeCzEYFbKjA/T2uDLTpkwGzCiq6soy8tYaI1GyVh/UjpbCx/TYkiZhlZB6+fzT"
      crossorigin="anonymous"
    />
  </head>
  <body class="text-bg-dark">
    <div class="container">
        <div class="row mt-5">
            <div class="col">
              <h3>Actualizar habitación</h3>
            </div>
        </div>
        <div class="div">
        <div class="container">
            <h5>Editar la información necesaria</h5>
            <form action="/updateRoom" method="post">
              <div class="col-md-6">
                <label for="idR" class="form-label">Id de habitación:</label>
                <input id="idR" name="idR" type="number" class="form-control" value="<%= `${room.idR}` %>" required>
              </div>  
              <div class="col-md-6">
                    <label for="roomNumber" class="form-label">Número de habitación:</label>
                    <input id="roomNumber" name="roomNumber" type="text" class="form-control" value="<%= `${room.roomNumber}` %>" required>
                </div>
                <div class="col-md-6">
                    <label for="roomType" class="form-label">Tipo de habitación:</label>
                    <input id="roomType" name="roomType" type="text" class="form-control" value="<%= `${room.roomType}` %>" required>
                </div>
                <div class="col-md-6">
                    <label for="roomPrice" class="form-label">Precio de la habitación:</label>
                    <input id="roomPrice" name="roomPrice" type="number" class="form-control" value="<%= `${room.roomPrice}` %>" required>
                </div>
                <div class="col-md-6">
                    <label for="roomStatus" class="form-label">Estado de la habitación:</label>
                    <input id="roomStatus" name="roomStatus" type="boolean" class="form-control" value="<%= `${room.roomStatus}` %>" required>
                </div>
                <input type="text" id="objId" name="objId" value="<%= `${room._id}` %>"><br><br>
                <input type="submit" value="Submit">
            </form>
        </div>
        </div>
    </div>
   
    <script
      src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.6/dist/umd/popper.min.js"
      integrity="sha384-oBqDVmMz9ATKxIep9tiCxS/Z9fNfEXiDAYTujMAeBAsjFuCZSmKbSSUnQlmh/jp3"
      crossorigin="anonymous"
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/js/bootstrap.min.js"
      integrity="sha384-7VPbUDkoPSGFnVtYi0QogXtr74QeVeeIs99Qfg5YCF+TidwNdjvaKZX19NZ/e6oz"
      crossorigin="anonymous"
    ></script>
  </body>
</html>