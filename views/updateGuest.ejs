<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mi Cuenta</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-iYQeCzEYFbKjA/T2uDLTpkwGzCiq6soy8tYaI1GyVh/UjpbCx/TYkiZhlZB6+fzT"
      crossorigin="anonymous"
    />
  </head>
  <body class="text-bg-dark">
    <div class="container">
        <div class="row mt-5">
            <div class="col">
              <h3>Actualizar datos del huésped</h3>
            </div>
        </div>
        <div class="div">
        <div class="container">
            <h5>Edita la información necesaria</h5>
            <form action="/routes/guests.js" method="post">
                <div class="col-md-6">
                    <label for="name" class="form-label">Nombre:</label>
                    <input id="name" name="name" type="text" class="form-control" value="<%= `${guest.name}` %>" required>
                </div>
                <div class="col-md-6">
                    <label for="lastName" class="form-label">Apellido:</label>
                    <input id="lastName" name="lastName" type="text" class="form-control" value="<%= `${guest.Lastname}` %>" required>
                </div>
                <div class="col-md-6">
                    <label for="email" class="form-label">Correo electrónico:</label>
                    <input id="email" name="email" type="email" class="form-control" value="<%= `${guest.email}` %>" required>
                </div>
                <div class="col-md-6">
                    <label for="phoneNumber" class="form-label">Número de teléfono:</label>
                    <input id="phoneNumber" name="phoneNumber" type="text" class="form-control" value="<%= `${guest.phoneNumber}` %>" required>
                </div>
                <div class="col-md-6">
                    <label for="roomNumber" class="form-label">Número de  habitación:</label>
                    <input id="roomNumber" name="roomNumber" type="text" class="form-control" value="<%= `${guest.roomNumber}` %>" required>
                </div>
                <div class="col-md-6">
                    <label for="checkInDate" class="form-label">Check In:</label>
                    <input id="checkInDate" name="checkInDate" type="date" class="form-control" value="<%= `${guest.checkInDate}` %>" required>
                </div>
                <div class="col-md-6">
                    <label for="checkOutDate" class="form-label">Check Out:</label>
                    <input id="checkOutDate" name="checkOutDate" type="date" class="form-control" value="<%= `${guest.checkOutDate}` %>" required>
                </div>
                <div class="col-md-6">
                    <label for="numberOfGuests" class="form-label">Número de personas:</label>
                    <input id="numberOfGuests" name="numberOfGuests" type="number" class="form-control" value="<%= `${guest.numberOfGuests}` %>" required>
                </div>
                <div class="col-md-6">
                    <label for="paymentMethod" class="form-label">Método de pago:</label>
                    <input id="paymentMethod" name="paymentMethod" type="text" class="form-control" value="<%= `${guest.paymentMethod}` %>" required>
                </div>

            </form>
        </div>
        </div>
        <div class="row mt-5">
            <div class="col">
                <a class="btn btn-block btn-primary"  className="saveAndUpload" href="home" role="button">Guardad y volver</a>
            </div>
            <div class="col">
                <a class="btn btn-block btn-primary"  className="discard" href="home" role="button">Descartar cambios</a>
            </div>
        </div>
    </div>
   
    <script
      src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.6/dist/umd/popper.min.js"
      integrity="sha384-oBqDVmMz9ATKxIep9tiCxS/Z9fNfEXiDAYTujMAeBAsjFuCZSmKbSSUnQlmh/jp3"
      crossorigin="anonymous"
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/js/bootstrap.min.js"
      integrity="sha384-7VPbUDkoPSGFnVtYi0QogXtr74QeVeeIs99Qfg5YCF+TidwNdjvaKZX19NZ/e6oz"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
