<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mi Cuenta</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-iYQeCzEYFbKjA/T2uDLTpkwGzCiq6soy8tYaI1GyVh/UjpbCx/TYkiZhlZB6+fzT"
      crossorigin="anonymous"
    />
  </head>
  <body class="text-bg-dark">
    <div class="container">
        <div class="row mt-5">
            <div class="col">
              <h3>¡Hola, Eduardo!</h3>
            </div>
        </div>
        <div class="container">
            <h5>Por favor completa la siguiente información:</h5>
            <form action="/routes/employees.js" method="post">
                <div class="col-md-6">
                    <label for="ename" class="form-label">Nombre:</label>
                    <input id="ename" name="ename" type="text" class="form-control" required>
                </div>
                <div class="col-md-6">
                    <label for="elastName" class="form-label">Apellido(s):</label>
                    <input id="elastName" name="elastName" type="text" class="form-control" required>
                </div>
                <div class="col-md-6">
                    <label for="eage" class="form-label"> Edad:</label>
                    <input id="eage" name="eage" type="number" class="form-control" required>
                </div>
                <div class="col-md-6">
                    <label for="eemail" class="form-label">Correo electrónico:</label>
                    <input id="eemail" name="eemail" type="email" class="form-control" required>
                </div>
                <div class="col-md-6">
                    <label for="epassword" class="form-label">Contraseña:</label>
                    <input id="epassword" name="epassword" type="password" class="form-control" required>
                </div>
                <div class="col-md-6">
                    <label for="erole" class="form-label">Rol:</label>
                    <input id="erole" name="erole" type="text" class="form-control" required>
                </div>
            </form>
        </div>
        <div class="row mt-5">
            <div class="col">
                <a class="btn btn-block btn-primary"  className="saveAndUpload" href="home" role="button">Guardad y volver</a>
            </div>
            <div class="col">
                <a class="btn btn-block btn-primary"  className="discard" href="home" role="button">Descartar cambios</a>
            </div>
        </div>
    </div>
   
    <script
      src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.6/dist/umd/popper.min.js"
      integrity="sha384-oBqDVmMz9ATKxIep9tiCxS/Z9fNfEXiDAYTujMAeBAsjFuCZSmKbSSUnQlmh/jp3"
      crossorigin="anonymous"
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/js/bootstrap.min.js"
      integrity="sha384-7VPbUDkoPSGFnVtYi0QogXtr74QeVeeIs99Qfg5YCF+TidwNdjvaKZX19NZ/e6oz"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
