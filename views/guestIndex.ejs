<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mi Cuenta</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-iYQeCzEYFbKjA/T2uDLTpkwGzCiq6soy8tYaI1GyVh/UjpbCx/TYkiZhlZB6+fzT"
      crossorigin="anonymous"
    />
  </head>
  <body class="text-bg-dark">
    <div class="container">
        <div class="row mt-5">
            <div class="col">
              <h3>Lista de huéspedes</h3>
            </div>
        </div>
        <div class="div">
          <table>

            <head>
              <tr>
                <th>
                  Id
                </th>
                <th>
                  Nombre
                </th>
                <th>
                  Apellido(S)
                </th>
                <th>
                  Correo electrónico
                </th>
                <th>
                  Número de teléfono
                </th>
                <th>
                  Número de habitación
                </th>
                <th>
                  Fecha de Check In
                </th>
                <th>
                  Fecha de Check Out 
                </th>
                <th>
                  Número de personas 
                </th>
                <th>
                  Método de pago
                </th>
              </tr>
            </head>
        
            <body>
              <% for(let i=0; i < guests.length; i++) { %>
              <tr>
                <td><%= guests[i].idG %></td>
                <td><%= guests[i].name %></td>
                <td><%= guests[i].lastName %></td>
                <td><%= guests[i].email %></td>
                <td><%= guests[i].phoneNumber %></td>
                <td><%= guests[i].roomNumber %></td>
                <td><%= guests[i].checkInDate %></td>
                <td><%= guests[i].checkOutDate %></td>
                <td><%= guests[i].numberOfGuests %></td>
                <td><%= guests[i].paymentMethod %></td>

                <td><a href="<%= `deleteGuest/${guests[i]._id}` %>">Eliminar</a> </td>
                <td><a href="<%= `findById/${guests[i]._id}` %>">Actualizar</a> </td>
        
              </tr>
              <% } %>
            </body>
          </table>
        </div>
        <div class="row mt-5">
            <div class="col">
                <a class="btn btn-block btn-primary"  className="discard" href="main" role="button">Volver al Inicio</a>
            </div>
        </div>
    </div>
   
    <script
      src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.6/dist/umd/popper.min.js"
      integrity="sha384-oBqDVmMz9ATKxIep9tiCxS/Z9fNfEXiDAYTujMAeBAsjFuCZSmKbSSUnQlmh/jp3"
      crossorigin="anonymous"
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/js/bootstrap.min.js"
      integrity="sha384-7VPbUDkoPSGFnVtYi0QogXtr74QeVeeIs99Qfg5YCF+TidwNdjvaKZX19NZ/e6oz"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
