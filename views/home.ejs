<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>IT Management Project</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-iYQeCzEYFbKjA/T2uDLTpkwGzCiq6soy8tYaI1GyVh/UjpbCx/TYkiZhlZB6+fzT"
      crossorigin="anonymous"
    />
  </head>
  <body class="text-bg-dark">
    <div class="container">
      <div class="row">
        <div class="col mt-4">
          <h1 class="text-center">Hotel Mirahermosa</h1>
          <!-- <img class="justify-content-center" src="/views/img/MH.jpg" width="1275" height="350" border-radius="50px"> -->
        </div>
      </div>
      <div class="row">
        <div class="col">
          <h3>¡Hola, Administrador!</h3>
        </div>
      </div>
      </div>
      <div class="row text-dark m-5 justify-content-center">
        <div class="col-md-5 col-ld-5 col-sm-12">
          <div class="card m-3">
            <img class="card-img-top" src="/views/img/guest.jpg" alt="Card image cap" width="600" height="400">
            <div class="card-body">
              <h5 class="card-title">Huéspedes</h5>
              <p class="card-text">En esta sección se incluye todo lo relacionado con los huéspedes, podrás agendar una nueva reservación ó
                consultar la lista de los todos huéspedes.
              </p>
              <a href="createGuest" class="btn btn-info">Nueva reservación</a>
              <a href="/api/guests" class="btn btn-info">Ver listado de huéspedes</a>
            </div>
          </div>
        </div>
        <div class="col-md-5 col-ld-5 col-sm-12">
          <div class="card m-3">
            <img class="card-img-top" src="/views/img/room.jpg" alt="Card image cap" width="600" height="400">
            <div class="card-body">
              <h5 class="card-title">Habitaciones</h5>
              <p class="card-text">En esta sección se podrá ver todo el listado de habitaciones disponibles para su reserva, junto con el precio y
                algunos otros detalles relacionados.
              </p>
              <a href="room" class="btn btn-info">Nueva habitación</a>
              <a href="/api/rooms" class="btn btn-info">Ver habitaciones</a>
            </div>
          </div>
        </div>
    </div>
    <div class="container text-bg-dark mb-5">
      <div class="card text-dark">
        <h5 class="card-header">Empleados</h5>
        <div class="card-body">
          <h5 class="card-title">Acciones de empleados</h5>
          <p class="card-text">En esta sección se puede crear, editar y visualizar a los actuales empleados.</p>
          <a class="btn btn-block btn-info" href="employee" role="button">Nuevo empleado</a>
          <a class="btn btn-block btn-info" href="/api/employees" role="button">Listado de empleados</a>
        </div>
      </div>
    </div>
    

    <script
      src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.6/dist/umd/popper.min.js"
      integrity="sha384-oBqDVmMz9ATKxIep9tiCxS/Z9fNfEXiDAYTujMAeBAsjFuCZSmKbSSUnQlmh/jp3"
      crossorigin="anonymous"
    ></script>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/js/bootstrap.min.js"
      integrity="sha384-7VPbUDkoPSGFnVtYi0QogXtr74QeVeeIs99Qfg5YCF+TidwNdjvaKZX19NZ/e6oz"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
